rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Restaurant logos
    match /logos/{restaurantId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        request.auth.uid in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.uid &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId == restaurantId;
    }
    
    // Menu item images
    match /menu/{restaurantId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        request.auth.uid in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.uid &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId == restaurantId;
    }
  }
}
